"""
Central Server Module - Federated Aggregation.
============================================================================
Paper Reference: Algorithm 2, Page 6; Section 4, Pages 4-5

Extensions for Byzantine Resilience and Non-IID handling:
1. FLTrust: Byzantine-resilient aggregation via trust-based filtering
   Reference: FLTRUST.pdf - "FLTrust: Byzantine-resilient Federated Learning
   via Trust Server" (Equation 7-8, Algorithm steps)

2. Fed+: Server-side momentum to correct client drift
   Reference: FED+.pdf - "FED+: A Unified Framework for Byzantine-Resilient
   Federated Learning" (Algorithm 1, momentum update rule)
============================================================================
"""

import torch
import copy
import numpy as np
from collections import OrderedDict


class CentralServer:
    """
    Central Server for Federated Model Aggregation.

    Supports multiple aggregation methods:
    1. 'attention' - Original paper's attention-weighted FedAvg (Algorithm 2)
    2. 'fltrust' - FLTrust Byzantine-resilient aggregation
    3. 'attention_fltrust' - Dynamic Attention + FLTrust combined
    4. 'fedplus' - Fed+ with server-side momentum for non-IID data
    5. 'fltrust_fedplus' - FLTrust + Fed+ combined
    6. 'attention_fltrust_fedplus' - Dynamic Attention + FLTrust + Fed+ combined (FULL)
    """

    def __init__(self, aggregate_method='attention', fltrust_tau=0.5,
                 fltrust_beta=0.5, fedplus_beta=0.9, fedplus_eta=1.0):
        """
        Initialize the central server.

        Args:
            aggregate_method: Aggregation method
                             'attention' - Original attention-weighted (Algorithm 2)
                             'fltrust'   - FLTrust Byzantine-resilient
                             'attention_fltrust' - Dynamic Attention + FLTrust combined
                             'fedplus'   - Fed+ with momentum
                             'fltrust_fedplus' - FLTrust + Fed+ combined
            fltrust_tau: Cosine similarity threshold τ (FLTrust)
                         Agents with cos(θ_i) < τ are excluded
                         Reference: FLTRUST.pdf, default τ = 0.5
            fltrust_beta: Dimension-wise suppression factor β (FLTrust)
                          Reference: FLTRUST.pdf, Equation 7
            fedplus_beta: Momentum coefficient β (Fed+)
                          Reference: FED+.pdf, Algorithm 1: m_{t+1} = β × m_t + ...
                          Typical value: 0.9
            fedplus_eta: Learning rate η for Fed+ model update
                         Reference: FED+.pdf: w_{t+1} = w_t - η × m_{t+1}
        """
        self.aggregated_weights = None
        self.round_number = 0
        self.aggregation_history = []
        self.aggregate_method = aggregate_method

        # FLTrust parameters
        self.fltrust_tau = fltrust_tau
        self.fltrust_beta = fltrust_beta

        # Fed+ parameters
        self.fedplus_beta = fedplus_beta
        self.fedplus_eta = fedplus_eta
        self.momentum = None  # Server momentum vector m_t

        # Proxy dataset for FLTrust (set via set_proxy_data)
        self.proxy_X = None
        self.proxy_y = None
        self.proxy_model = None  # Copy of model to compute gradient direction

    def set_proxy_data(self, proxy_X, proxy_y, model_template):
        """
        Set proxy dataset for FLTrust Byzantine detection.

        FLTrust requires a small clean proxy dataset D_0 at the server
        to compute a "trusted direction" d_0 for comparison.

        Reference: FLTRUST.pdf - "the server has access to a small clean
        proxy dataset D_0 (e.g., 0.1% of total data)"

        Args:
            proxy_X: Proxy dataset features [N_proxy, feature_dim]
            proxy_y: Proxy dataset labels [N_proxy]
            model_template: A model instance to copy architecture for
                          computing gradient direction
        """
        self.proxy_X = proxy_X
        self.proxy_y = proxy_y
        # Store a copy of model architecture for gradient computation
        self.proxy_model = copy.deepcopy(model_template)

    def _compute_model_difference(self, weights1, weights2):
        """
        Compute the model update vector Δw = w_new - w_old as a flattened tensor.

        This is the "gradient direction" used in FLTrust.

        Reference: FLTRUST.pdf - "Δ_w_i denotes the model update from client i"
        Direction d_i = Δ_w_i / ||Δ_w_i||

        Args:
            weights1: First model state_dict (old weights)
            weights2: Second model state_dict (new weights)
        Returns:
            delta_w: Flattened difference vector
        """
        delta_parts = []
        for key in weights1:
            # Flatten and concatenate each layer's difference
            diff = weights2[key].float() - weights1[key].float()
            delta_parts.append(diff.flatten())

        delta_w = torch.cat(delta_parts)
        return delta_w

    def _flatten_weights(self, weights):
        """
        Flatten model weights into a single vector.

        Used for cosine similarity and distance computations.

        Args:
            weights: state_dict
        Returns:
            Flattened weights vector
        """
        parts = []
        for key in weights:
            parts.append(weights[key].float().flatten())
        return torch.cat(parts)

    def _compute_proxy_gradient_direction(self, current_weights):
        """
        Compute the trusted direction d_0 from proxy dataset.

        Reference: FLTRUST.pdf - "Server computes the direction d_0 of its
        own root model update on the proxy data"

        Steps:
        1. Load current global weights to proxy model
        2. Compute gradient on proxy data (using a simple forward pass loss)
        3. Direction d_0 = gradient / ||gradient||

        Note: Since we use flat features (not gradient descent), we compute
        direction as: d_0 = (w_proxy - w_current) / ||w_proxy - w_current||

        Args:
            current_weights: Current global model weights
        Returns:
            d_0: Trusted direction vector (normalized)
        """
        if self.proxy_X is None or self.proxy_y is None:
            raise ValueError(
                "Proxy data not set. Call set_proxy_data() before using FLTrust."
            )

        # Compute proxy model update direction
        # Method: compute gradient approximation by forward pass on proxy data
        proxy_model = copy.deepcopy(self.proxy_model)
        proxy_model.load_state_dict(copy.deepcopy(current_weights))
        proxy_model.train()

        # Simple gradient approximation: compute "pseudo-gradient" direction
        # by doing one step of training on proxy data
        optimizer = torch.optim.SGD(proxy_model.parameters(), lr=0.01)
        criterion = torch.nn.CrossEntropyLoss()

        X_tensor = torch.FloatTensor(self.proxy_X)
        y_tensor = torch.LongTensor(self.proxy_y)

        # Forward pass
        outputs = proxy_model(X_tensor)

        # Handle PPO models that return (action_probs, value) tuple
        # Proxy gradient only needs the classification logits
        if isinstance(outputs, tuple):
            logits = outputs[0]  # PPO: (action_probs, value) — only logits for loss
        else:
            logits = outputs

        loss = criterion(logits, y_tensor)

        # Backward pass to get gradients
        optimizer.zero_grad()
        loss.backward()

        # Collect gradients
        grad_parts = []
        for param in proxy_model.parameters():
            if param.grad is not None:
                grad_parts.append(param.grad.flatten())

        if len(grad_parts) == 0:
            # Fallback: use weight difference method
            # Train proxy model briefly
            for _ in range(5):
                optimizer.zero_grad()
                outputs = proxy_model(X_tensor)
                if isinstance(outputs, tuple):
                    logits = outputs[0]
                else:
                    logits = outputs
                loss = criterion(logits, y_tensor)
                loss.backward()
                optimizer.step()

            delta_w = self._compute_model_difference(current_weights, proxy_model.state_dict())
            d_0 = delta_w / (torch.norm(delta_w) + 1e-8)
            return d_0

        gradient = torch.cat(grad_parts)
        d_0 = gradient / (torch.norm(gradient) + 1e-8)

        return d_0

    def _compute_fltrust_trust_scores(self, agent_deltas, d_0):
        """
        Compute FLTrust trust scores for each agent.

        Reference: FLTRUST.pdf, Equation 7:
        TS_k(i) = [cos(θ_i) × (1 - ||d_i - d_0|| / √d)] / 2

        Alternative form mentioned in paper:
        TS_k(i) = (cos(θ_i) + 1) / 2 × (1 - ||d_i - d_0|| / √d)

        Args:
            agent_deltas: List of model update vectors Δw_i (flattened)
            d_0: Trusted direction vector from proxy data
        Returns:
            trust_scores: List of trust scores per agent
            trusted_indices: Indices of agents that passed filtering
        """
        d = len(d_0)  # Dimensionality
        sqrt_d = np.sqrt(d)

        trust_scores = []
        trusted_indices = []

        for i, delta_i in enumerate(agent_deltas):
            # Normalize to get direction d_i
            norm_i = torch.norm(delta_i)
            if norm_i < 1e-8:
                # Zero update - assign small trust
                d_i = torch.zeros_like(d_0)
            else:
                d_i = delta_i / norm_i

            # Cosine similarity: cos(θ_i) = <d_i, d_0> / (||d_i|| × ||d_0||)
            # Since both are normalized, cos = dot product
            cos_theta = torch.dot(d_i, d_0).item()

            # ==== Tier 1: Cosine Similarity Filtering ====
            # Reference: FLTRUST.pdf - "cos(θ_i) < τ → exclude"
            if cos_theta < self.fltrust_tau:
                # Agent is Byzantine or malfunctioning - exclude
                continue

            # Euclidean distance in direction space
            # ||d_i - d_0||
            dist = torch.norm(d_i - d_0).item()

            # ==== Trust Score Computation (Equation 7) ====
            # TS = (cos(θ_i) + 1) / 2 × (1 - ||d_i - d_0|| / √d)
            # Range: [0, 1], higher is more trusted
            ts = ((cos_theta + 1) / 2) * (1 - dist / sqrt_d)

            trust_scores.append(ts)
            trusted_indices.append(i)

        return trust_scores, trusted_indices

    def _aggregate_fltrust(self, agent_weights, attention_values, agent_deltas, d_0):
        """
        FLTrust aggregation: Byzantine-resilient with trust-based weighting.

        Reference: FLTRUST.pdf, Equation 8:
        g_trusted = Σ_{i∈S} TS_k(i) × g_i / Σ_{i∈S} TS_k(i)
        where g_i = gradient update from agent i

        Args:
            agent_weights: List of state_dicts
            attention_values: List of attention values (not used in FLTrust)
            agent_deltas: List of flattened update vectors
            d_0: Trusted direction from proxy data
        Returns:
            aggregated: OrderedDict of aggregated weights
        """
        trust_scores, trusted_indices = self._compute_fltrust_trust_scores(
            agent_deltas, d_0
        )

        if len(trusted_indices) == 0:
            # All agents filtered - fall back to uniform average
            print("[FLTrust] WARNING: All agents filtered! Using uniform average.")
            uniform_weights = [1.0 / len(agent_weights)] * len(agent_weights)
            return self._aggregate_attention(agent_weights, uniform_weights)

        # Normalize trust scores to sum to 1
        total_ts = sum(trust_scores)
        normalized_weights = [ts / total_ts for ts in trust_scores]

        # Log filtering statistics
        self.aggregation_history[-1]['fltrust'] = {
            'total_agents': len(agent_weights),
            'trusted_agents': len(trusted_indices),
            'filtered_indices': [i for i in range(len(agent_weights)) if i not in trusted_indices],
            'trust_scores': trust_scores,
        }

        # Aggregate using trust scores as weights
        return self._aggregate_attention(
            [agent_weights[i] for i in trusted_indices],
            normalized_weights
        )

    def _aggregate_fedplus(self, agent_weights, attention_values, previous_weights):
        """
        Fed+ aggregation: Server-side momentum for non-IID data correction.

        Reference: FED+.pdf, Algorithm 1:
        m_{t+1} = β × m_t + Σ_{i∈S} (n_i / n) × Δ_w_i
        w_{t+1} = w_t - η × m_{t+1}

        The momentum term m_t acts as a "memory" of past gradient updates,
        correcting client drift caused by non-IID data distributions.

        Args:
            agent_weights: List of state_dicts (W_i after local training)
            attention_values: List of attention values (used as sample counts n_i)
            previous_weights: Global model weights from previous round
        Returns:
            aggregated: OrderedDict of aggregated weights
        """
        num_agents = len(agent_weights)
        total_samples = sum(attention_values) if sum(attention_values) > 0 else num_agents

        # Compute model updates Δ_w_i = W_i - W_global
        delta_ws = []
        for i in range(num_agents):
            delta_w = self._compute_model_difference(previous_weights, agent_weights[i])
            delta_ws.append(delta_w)

        # Weighted sum of updates: Σ (n_i/n) × Δ_w_i
        weighted_delta = torch.zeros_like(delta_ws[0])
        for i, delta_w in enumerate(delta_ws):
            weight = attention_values[i] / total_samples
            weighted_delta += weight * delta_w

        # Update momentum: m_{t+1} = β × m_t + weighted_delta
        if self.momentum is None:
            self.momentum = weighted_delta
        else:
            self.momentum = self.fedplus_beta * self.momentum + weighted_delta

        # Update global model: w_{t+1} = w_t - η × m_{t+1}
        # Note: model weights are accumulated from initial, so we subtract momentum
        new_weights = OrderedDict()
        prev_flat = self._flatten_weights(previous_weights)
        new_flat = prev_flat - self.fedplus_eta * self.momentum

        # Reconstruct state_dict
        idx = 0
        for key in previous_weights:
            numel = previous_weights[key].numel()
            size = previous_weights[key].size()
            new_weights[key] = new_flat[idx:idx + numel].view(size).clone()
            idx += numel

        return new_weights

    def _aggregate_fltrust_fedplus(self, agent_weights, attention_values,
                                    previous_weights, agent_deltas, d_0):
        """
        Combine FLTrust filtering with Fed+ momentum aggregation.

        First filter out Byzantine agents using FLTrust cosine similarity,
        then aggregate remaining agents using Fed+ momentum.

        Reference: FLTRUST.pdf + FED+.pdf combined

        Args:
            agent_weights: List of state_dicts
            attention_values: List of attention values (sample counts)
            previous_weights: Global model weights from previous round
            agent_deltas: List of flattened update vectors
            d_0: Trusted direction from proxy data
        Returns:
            aggregated: OrderedDict of aggregated weights
        """
        trust_scores, trusted_indices = self._compute_fltrust_trust_scores(
            agent_deltas, d_0
        )

        if len(trusted_indices) == 0:
            print("[FLTrust+Fed+] WARNING: All agents filtered! Using uniform average.")
            uniform_weights = [1.0 / len(agent_weights)] * len(agent_weights)
            return self._aggregate_attention(agent_weights, uniform_weights)

        # Filter to only trusted agents
        trusted_weights = [agent_weights[i] for i in trusted_indices]
        trusted_attention = [attention_values[i] for i in trusted_indices]

        # Log filtering statistics
        self.aggregation_history[-1]['fltrust'] = {
            'total_agents': len(agent_weights),
            'trusted_agents': len(trusted_indices),
            'filtered_indices': [i for i in range(len(agent_weights)) if i not in trusted_indices],
            'trust_scores': trust_scores,
        }

        # Apply Fed+ on trusted agents only
        return self._aggregate_fedplus(trusted_weights, trusted_attention, previous_weights)

    def _aggregate_attention_fltrust_fedplus(self, agent_weights, attention_values,
                                              previous_weights, agent_deltas, d_0):
        """
        KẾT HỢP ĐẦY ĐỦ: Dynamic Attention + FLTrust + Fed+ — Complete Defense.

        =========================================================================
        TẠI SAO CẦN KẾT HỢP CẢ 3?
        =========================================================================
        1. Dynamic Attention (bài báo gốc Algorithm 3):
           → Weight theo accuracy + data quantity
           → Ưu điểm: Agent có dữ liệu nhiều và accuracy cao được weight cao hơn
           → Nhược điểm: Không phát hiện được Byzantine agents

        2. FLTrust (FLTRUST.pdf):
           → Lọc Byzantine agents bằng cosine similarity với proxy gradient
           → Ưu điểm: Loại bỏ agents gửi model độc hại
           → Nhược điểm: Không dùng accuracy-based weighting

        3. Fed+ (FED+.pdf):
           → Server-side momentum để correct client drift
           → Ưu điểm: Hội tụ tốt hơn với non-IID data
           → Nhược điểm: Không có Byzantine defense

        =========================================================================
        KẾT HỢP: weight = attention × trust_score, rồi apply Fed+ momentum
        =========================================================================
        Output = Fed+( attention × trust_score × W_i )
        Trong đó:
          - attention_i từ Algorithm 3 (accuracy + data quantity)
          - trust_score_i từ FLTrust (cosine similarity)
          - Fed+ momentum giúp hội tụ ổn định hơn với non-IID

        =========================================================================
        THUẬT TOÁN CHI TIẾT (Step-by-step)
        =========================================================================
        Input: agent_weights, attention_values, previous_weights, agent_deltas, d_0

        Step 1: Tính attention_i từ Dynamic Attention (Algorithm 3)
                → attention_i = n_i × (1 + k×(1-acc_i)×a^(-acc_i))

        Step 2: Tính trust_score_i từ FLTrust (Equation 7)
                → d_i = Δw_i / ||Δw_i|| (direction của agent i)
                → cos(θ_i) = <d_i, d_0> (cosine với proxy gradient)
                → Nếu cos(θ_i) < τ → trust_score = 0 (Byzantine)
                → Nếu cos(θ_i) ≥ τ → TS_i = ((cos+1)/2) × (1 - ||d_i-d_0||/√d)

        Step 3: Combined base_weight = attention_i × trust_score_i
                → Byzantine agents có trust_score=0 → weight=0 → bị loại

        Step 4: Normalize: base_weight_i = base_weight_i / Σ(base_weight_j)

        Step 5: Áp dụng Fed+ momentum:
                → m_{t+1} = β × m_t + Σ weight_i × Δw_i
                → w_{t+1} = w_t - η × m_{t+1}

        Reference:
          - Dynamic Attention: Algorithm 3, Paper
          - FLTrust: FLTRUST.pdf, Equations 7-8
          - Fed+: FED+.pdf, Algorithm 1

        Args:
            agent_weights: List of state_dicts
            attention_values: List of attention values (from Dynamic Attention, Algorithm 3)
            previous_weights: Global model weights from previous round (for Fed+)
            agent_deltas: List of flattened update vectors Δw_i (for FLTrust)
            d_0: Trusted direction from proxy data (for FLTrust)
        Returns:
            aggregated: OrderedDict of aggregated weights
        """
        num_agents = len(agent_weights)
        d = len(d_0)  # Dimensionality for distance normalization
        sqrt_d = np.sqrt(d)

        # ==== Step 1: Compute attention weights (Algorithm 3, Paper) ====
        # attention_i = n_i × (1 + k×(1-acc_i)×a^(-acc_i))
        # Đã được tính sẵn trong attention_values từ AttentionManager
        # attention_values[i] chính là attention_i

        # ==== Step 2: Compute FLTrust trust scores ====
        # Reference: FLTRUST.pdf, Equation 7
        # TS_k(i) = (cos(θ_i) + 1) / 2 × (1 - ||d_i - d_0|| / √d)
        trust_scores = []
        for i, delta_i in enumerate(agent_deltas):
            # Normalize delta to get direction d_i
            # Reference: FLTRUST.pdf: "d_i = Δ_w_i / ||Δ_w_i||"
            norm_i = torch.norm(delta_i)
            if norm_i < 1e-8:
                d_i = torch.zeros_like(d_0)
            else:
                d_i = delta_i / norm_i

            # Cosine similarity: cos(θ_i) = <d_i, d_0>
            # Reference: FLTRUST.pdf
            cos_theta = torch.dot(d_i, d_0).item()

            # ==== Byzantine filtering: cos(θ_i) < τ → trust_score = 0 ====
            # Reference: FLTRUST.pdf - "cos(θ_i) < τ → exclude client i"
            if cos_theta < self.fltrust_tau:
                trust_scores.append(0.0)
                continue

            # Euclidean distance: ||d_i - d_0||
            dist = torch.norm(d_i - d_0).item()

            # Trust Score computation
            # Reference: FLTRUST.pdf, Equation 7
            ts = ((cos_theta + 1) / 2) * (1 - dist / sqrt_d)
            trust_scores.append(ts)

        # ==== Step 3: Combined weight = attention × trust_score ====
        # Weight_i = attention_i × trust_score_i
        # Byzantine agents (trust_score=0) → weight=0 → bị loại
        combined_weights = [
            attention_values[i] * trust_scores[i]
            for i in range(num_agents)
        ]

        # ==== Step 4: Normalize ====
        total_combined = sum(combined_weights)
        if total_combined == 0:
            print("[Attention+FLTrust+Fed+] WARNING: All agents filtered! "
                  "Using uniform average.")
            normalized_weights = [1.0 / num_agents] * num_agents
        else:
            normalized_weights = [w / total_combined for w in combined_weights]

        # Log chi tiết để debug
        self.aggregation_history[-1]['attention_fltrust_fedplus'] = {
            'total_agents': num_agents,
            'attention_values': list(attention_values),
            'trust_scores': trust_scores,
            'combined_weights': combined_weights,
            'normalized_weights': normalized_weights,
            'filtered_agents': [
                i for i in range(num_agents) if trust_scores[i] < 1e-8
            ],
        }

        # ==== Step 5: Áp dụng Fed+ momentum trên trusted agents ====
        # Reference: FED+.pdf, Algorithm 1
        # m_{t+1} = β × m_t + Σ weight_i × Δw_i
        # w_{t+1} = w_t - η × m_{t+1}

        # Compute weighted deltas
        delta_ws = []
        for i in range(num_agents):
            delta_w = self._compute_model_difference(previous_weights, agent_weights[i])
            delta_ws.append(delta_w)

        # Weighted sum: Σ weight_i × Δw_i
        weighted_delta = torch.zeros_like(delta_ws[0])
        for i, delta_w in enumerate(delta_ws):
            weighted_delta += normalized_weights[i] * delta_w

        # Update momentum: m_{t+1} = β × m_t + weighted_delta
        if self.momentum is None:
            self.momentum = weighted_delta
        else:
            self.momentum = self.fedplus_beta * self.momentum + weighted_delta

        # Update global model: w_{t+1} = w_t - η × m_{t+1}
        new_weights = OrderedDict()
        prev_flat = self._flatten_weights(previous_weights)
        new_flat = prev_flat - self.fedplus_eta * self.momentum

        # Reconstruct state_dict
        idx = 0
        for key in previous_weights:
            numel = previous_weights[key].numel()
            size = previous_weights[key].size()
            new_weights[key] = new_flat[idx:idx + numel].view(size).clone()
            idx += numel

        return new_weights

    def _aggregate_attention_fltrust(self, agent_weights, attention_values,
                                      agent_deltas, d_0):
        """
        KẾT HỢP Dynamic Attention + FLTrust — Byzantine-resilient Attention-weighted.

        =========================================================================
        TẠI SAO CẦN KẾT HỢP?
        =========================================================================
        1. Dynamic Attention (bài báo gốc Algorithm 3):
           - Ưu điểm: Weight theo accuracy + data quantity
           - Nhược điểm: Không có cơ chế phát hiện Byzantine/poisoned agents
           - Công thức: attention_i = n_i × (1 + k×(1-acc_i)×a^(-acc_i))

        2. FLTrust (FLTRUST.pdf):
           - Ưu điểm: Lọc Byzantine agents qua cosine similarity với proxy gradient
           - Nhược điểm: Không dùng accuracy-based weighting
           - Công thức: TS_i = (cos+1)/2 × (1 - ||d_i-d_0||/√d)

        3. Kết hợp: attention × trust_score
           - Dùng attention values (từ Algorithm 3) làm base weights
           - Dùng FLTrust trust scores để điều chỉnh/filter
           - Agent nào có trust_score = 0 (cos < τ) → bị loại hoàn toàn
           - Agent nào có trust_score > 0 → weight = attention_i × trust_score_i

        =========================================================================
        THUẬT TOÁN KẾT HỢP (Step-by-step)
        =========================================================================
        Input: agent_weights, attention_values (từ Dynamic Attention),
               agent_deltas, d_0 (proxy gradient direction)

        Step 1: Tính FLTrust trust scores cho mỗi agent
                TS_i = (cos(θ_i) + 1) / 2 × (1 - ||d_i-d_0||/√d)
                (FLTRUST.pdf, Equation 7)

        Step 2: Agent nào có cos(θ_i) < τ → trust_score = 0 (Byzantine)

        Step 3: Combined weight_i = attention_i × trust_score_i

        Step 4: Normalize: weight_i = weight_i / Σ(weight_j)

        Step 5: Aggregate: W_agg = Σ weight_i × W_i

        Reference: Kết hợp từ Algorithm 3 (Paper) + FLTRUST.pdf Equations 7-8

        Args:
            agent_weights: List of state_dicts
            attention_values: List of attention values (from Dynamic Attention)
            agent_deltas: List of flattened update vectors Δw_i
            d_0: Trusted direction from proxy data
        Returns:
            aggregated: OrderedDict of aggregated weights
        """
        num_agents = len(agent_weights)
        d = len(d_0)  # Dimensionality for distance normalization
        sqrt_d = np.sqrt(d)

        # ==== Step 1: Tính FLTrust trust scores ====
        # Reference: FLTRUST.pdf, Equation 7
        # TS_k(i) = (cos(θ_i) + 1) / 2 × (1 - ||d_i - d_0|| / √d)
        trust_scores = []
        for i, delta_i in enumerate(agent_deltas):
            # Normalize delta to get direction d_i
            # Reference: FLTRUST.pdf: "d_i = Δ_w_i / ||Δ_w_i||"
            norm_i = torch.norm(delta_i)
            if norm_i < 1e-8:
                d_i = torch.zeros_like(d_0)
            else:
                d_i = delta_i / norm_i

            # Cosine similarity: cos(θ_i) = <d_i, d_0>
            # Reference: FLTRUST.pdf
            cos_theta = torch.dot(d_i, d_0).item()

            # ==== Step 2: Byzantine filtering ====
            # cos(θ_i) < τ → trust_score = 0 (loại bỏ)
            # Reference: FLTRUST.pdf - "cos(θ_i) < τ → exclude client i"
            if cos_theta < self.fltrust_tau:
                trust_scores.append(0.0)
                continue

            # Euclidean distance: ||d_i - d_0||
            dist = torch.norm(d_i - d_0).item()

            # Trust Score: (cos + 1)/2 × (1 - dist/√d)
            # Reference: FLTRUST.pdf, Equation 7
            ts = ((cos_theta + 1) / 2) * (1 - dist / sqrt_d)
            trust_scores.append(ts)

        # ==== Step 3: Combined weight = attention × trust_score ====
        # Weight_i = attention_i × trust_score_i
        # Nếu trust_score_i = 0 → agent bị loại (weight = 0)
        combined_weights = [
            attention_values[i] * trust_scores[i]
            for i in range(num_agents)
        ]

        # ==== Step 4: Normalize ====
        total_combined = sum(combined_weights)
        if total_combined == 0:
            # Fallback: uniform average nếu tất cả đều bị filter
            print("[Attention+FLTrust] WARNING: All agents filtered or zero attention! "
                  "Using uniform average.")
            normalized_weights = [1.0 / num_agents] * num_agents
        else:
            normalized_weights = [w / total_combined for w in combined_weights]

        # Log chi tiết để debug
        self.aggregation_history[-1]['attention_fltrust'] = {
            'total_agents': num_agents,
            'attention_values': list(attention_values),
            'trust_scores': trust_scores,
            'combined_weights': combined_weights,
            'normalized_weights': normalized_weights,
            'filtered_agents': [
                i for i in range(num_agents) if trust_scores[i] < 1e-8
            ],
        }

        # ==== Step 5: Aggregate ====
        # Reference: Algorithm 2, Line 4: W_agg = Σ w_i × W_i
        return self._aggregate_attention(agent_weights, normalized_weights)

    def _aggregate_attention(self, agent_weights, attention_values):
        """
        Original attention-weighted aggregation (Algorithm 2, Paper).

        Reference: Algorithm 2, Lines 1-7, Page 6

        Args:
            agent_weights: List of state_dicts
            attention_values: List of attention weights
        Returns:
            aggregated: OrderedDict of aggregated weights
        """
        num_agents = len(agent_weights)
        total_attention = sum(attention_values)

        if total_attention == 0:
            total_attention = 1.0

        reference_weights = agent_weights[0]
        w_sum = OrderedDict()
        for key in reference_weights:
            w_sum[key] = torch.zeros_like(reference_weights[key], dtype=torch.float32)

        for k in range(num_agents):
            ak = attention_values[k]
            wk = agent_weights[k]
            for key in w_sum:
                w_sum[key] += ak * wk[key].float()

        aggregated = OrderedDict()
        for key in w_sum:
            aggregated[key] = w_sum[key] / total_attention

        return aggregated

    def aggregate(self, agent_weights, attention_values, previous_weights=None):
        """
        Perform model aggregation using the configured method.

        Paper Reference: Algorithm 2, Lines 1-7, Page 6 (for attention method)

        FLTrust Reference: FLTRUST.pdf, Equations 7-8, Algorithm steps
        Fed+ Reference: FED+.pdf, Algorithm 1: momentum update rule

        Args:
            agent_weights: List of state_dicts, one per agent [W1, W2, ..., WN]
            attention_values: List of attention values [A1, A2, ..., AN]
                             For Fed+, this is used as sample counts (n_i)
            previous_weights: Previous global model weights (required for Fed+)
                             For Fed+/FLTrust+Fed+ methods
        Returns:
            aggregated: OrderedDict of aggregated model weights (W_agg)
        """
        assert len(agent_weights) == len(attention_values), \
            "Number of agent weights must match number of attention values"

        num_agents = len(agent_weights)
        self.round_number += 1

        # Compute model deltas for FLTrust-based methods
        agent_deltas = []
        if self.aggregate_method in ['fltrust', 'fltrust_fedplus', 'attention_fltrust', 'attention_fltrust_fedplus']:
            if previous_weights is None:
                # First round: use zero deltas
                for _ in range(num_agents):
                    agent_deltas.append(torch.zeros(
                        self._flatten_weights(agent_weights[0]).shape
                    ))
            else:
                for i in range(num_agents):
                    delta = self._compute_model_difference(
                        previous_weights, agent_weights[i]
                    )
                    agent_deltas.append(delta)

        # Compute trusted direction d_0 for FLTrust methods
        d_0 = None
        if self.aggregate_method in ['fltrust', 'fltrust_fedplus', 'attention_fltrust', 'attention_fltrust_fedplus']:
            if previous_weights is not None:
                d_0 = self._compute_proxy_gradient_direction(previous_weights)

        # Initialize history entry — append FIRST before any log writes
        history_entry = {
            'round': self.round_number,
            'num_agents': num_agents,
            'method': self.aggregate_method,
            'attention_values': list(attention_values),
        }
        self.aggregation_history.append(history_entry)

        # Route to appropriate aggregation method
        if self.aggregate_method == 'attention':
            aggregated = self._aggregate_attention(agent_weights, attention_values)

        elif self.aggregate_method == 'fltrust':
            # Round-1 fallback: no previous_weights → use uniform average, skip FLTrust filtering
            if previous_weights is None or d_0 is None:
                print("[FLTrust] Round 1: no previous_weights/d_0, falling back to uniform average")
                aggregated = self._aggregate_attention(agent_weights, [1.0 / num_agents] * num_agents)
                self.aggregation_history[-1]['fltrust'] = {
                    'round_1_fallback': True,
                    'reason': 'previous_weights or d_0 not available',
                }
            else:
                aggregated = self._aggregate_fltrust(
                    agent_weights, attention_values, agent_deltas, d_0
                )

        elif self.aggregate_method == 'attention_fltrust':
            # Round-1 fallback: uniform attention weights, skip FLTrust filtering
            if previous_weights is None or d_0 is None:
                print("[Attention+FLTrust] Round 1: falling back to uniform average")
                aggregated = self._aggregate_attention(agent_weights, [1.0 / num_agents] * num_agents)
                self.aggregation_history[-1]['attention_fltrust'] = {
                    'round_1_fallback': True,
                }
            else:
                aggregated = self._aggregate_attention_fltrust(
                    agent_weights, attention_values, agent_deltas, d_0
                )

        elif self.aggregate_method == 'fedplus':
            if previous_weights is None:
                # Round-1 fallback: standard attention aggregation without momentum
                print("[Fed+] Round 1: no previous_weights, falling back to attention")
                aggregated = self._aggregate_attention(agent_weights, attention_values)
                self.aggregation_history[-1]['fedplus'] = {
                    'round_1_fallback': True,
                    'momentum_applied': False,
                }
            else:
                aggregated = self._aggregate_fedplus(
                    agent_weights, attention_values, previous_weights
                )
                self.aggregation_history[-1]['fedplus'] = {
                    'round_1_fallback': False,
                    'momentum_applied': True,
                }

        elif self.aggregate_method == 'fltrust_fedplus':
            if previous_weights is None or d_0 is None:
                print("[FLTrust+Fed+] Round 1: falling back to uniform average")
                aggregated = self._aggregate_attention(agent_weights, [1.0 / num_agents] * num_agents)
                self.aggregation_history[-1]['fltrust_fedplus'] = {
                    'round_1_fallback': True,
                }
            else:
                aggregated = self._aggregate_fltrust_fedplus(
                    agent_weights, attention_values, previous_weights,
                    agent_deltas, d_0
                )

        elif self.aggregate_method == 'attention_fltrust_fedplus':
            if previous_weights is None or d_0 is None:
                print("[Attention+FLTrust+Fed+] Round 1: falling back to uniform average")
                aggregated = self._aggregate_attention(agent_weights, [1.0 / num_agents] * num_agents)
                self.aggregation_history[-1]['attention_fltrust_fedplus'] = {
                    'round_1_fallback': True,
                }
            else:
                aggregated = self._aggregate_attention_fltrust_fedplus(
                    agent_weights, attention_values, previous_weights,
                    agent_deltas, d_0
                )

        else:
            raise ValueError(f"Unknown aggregation method: {self.aggregate_method}")

        self.aggregated_weights = aggregated

        return aggregated

    def get_aggregated_weights(self):
        """
        Get the aggregated model weights.

        Paper Reference: Algorithm 2, Line 8, Page 6
        "Send the computed W_agg to all the participating agents"
        """
        return copy.deepcopy(self.aggregated_weights)

    def get_aggregation_history(self):
        """Get all aggregation statistics for analysis."""
        return self.aggregation_history

    def reset_momentum(self):
        """Reset Fed+ momentum vector (call at start of new training)."""
        self.momentum = None
